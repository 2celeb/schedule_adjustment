# 環境変数テンプレート
# このファイルをコピーして .env を作成してください:
#   cp .env.example .env
# 各値を実際の認証情報に置き換えてください

# Discord Bot
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Rails
RAILS_SECRET_KEY_BASE=your_secret_key_base_here
DATABASE_URL=postgres://postgres:password@db:5432/schedule_dev
REDIS_URL=redis://redis:6379/0

# CORS 許可オリジン（カンマ区切り）
CORS_ORIGINS=http://localhost:5173,http://localhost

# Active Record 暗号化キー（本番環境では必ず変更してください）
# rails db:encryption:init で生成可能
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=your_primary_key_here
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=your_deterministic_key_here
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=your_key_derivation_salt_here

# Bot → Rails 内部 API 認証
INTERNAL_API_TOKEN=your_internal_api_token_here
